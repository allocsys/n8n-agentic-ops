{
  "name": "n8n-crm-worker",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:create": "wrangler d1 create n8n-crm-worker-db",
    "db:migrate:local": "wrangler d1 execute n8n-crm-worker-db --file=./schema.sql",
    "db:migrate:remote": "wrangler d1 execute n8n-crm-worker-db --file=./schema.sql --remote"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.18.6",
    "vitest": "^4.1.0",
    "wrangler": "^4.113.0"
  }
}
